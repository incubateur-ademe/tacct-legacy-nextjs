{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(rtk grep:*)",
      "Bash(rtk read:*)",
      "Bash(rtk find:*)",
      "Bash(rtk ls:*)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./deploy/deploy.env)",
      "Read(./**/.env)",
      "Bash(cat:*.env*)",
      "Bash(rtk read:*.env*)"
    ]
  }
}
