# ──────────────────────────────────────────────────────────────────────────────
# TACCT – Variables d'environnement
# Copier ce fichier en `.env.local` (ou `.env`) et remplir les valeurs.
# ──────────────────────────────────────────────────────────────────────────────

# ── Application ──
APP_URL="http://localhost:3000"
NODE_ENV="development"

# ── Database (Postgres) ──
# Format: postgresql://USER:PASSWORD@HOST:PORT/DB?schema=public
DATABASE_URL="postgresql://tacct:tacct@localhost:5432/tacct?schema=public"
# Optionnel : chemin vers le certificat CA pour valider strictement la connexion SSL.
# Si non défini ET que l'URL contient sslmode=…, la vérification du CA est désactivée
# (utile pour les hosts à CA self-signed comme Scalingo en dev).
DATABASE_CA_PATH=""

# ── Dev impersonation ──
# Tant que ProConnect n'est pas branché, on impersonne un user par son email.
# Doit correspondre à un user.email présent en base.
DEV_AUTH_EMAIL="celine.vanhautere.ext@ademe.fr"

# ── Auth.js (NextAuth v5) ── (à brancher en dernière phase)
# Générer avec : openssl rand -base64 32  (ou `pnpm exec auth secret`)
AUTH_SECRET=""
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ── ProConnect (OIDC) ──
# Doc : https://partenaires.proconnect.gouv.fr/
# Issuer prod : https://auth.agentconnect.gouv.fr/api/v2
# Issuer integ : https://fca.integ01.dev-agentconnect.fr/api/v2
PROCONNECT_ISSUER="https://fca.integ01.dev-agentconnect.fr/api/v2"
PROCONNECT_CLIENT_ID=""
PROCONNECT_CLIENT_SECRET=""

# ── Mail (SMTP) ──
# Deux façons de configurer (le code essaie MAILER_DSN d'abord, sinon MAILER_HOST…).
# NE JAMAIS mettre de vraie clé/mot de passe ici : ce fichier est versionné.
# Les vraies valeurs vont dans .env.local (dev) ou les variables d'env de prod.
#
#  • DEV : Mailpit / Mailhog en local (capture les mails, ne les envoie pas).
#          docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit  → UI http://localhost:8025
MAILER_DSN="smtp://localhost:1025"
#
#  • PROD (recommandé) : variables séparées — pas d'encodage URL à gérer.
#    Exemple Brevo (offre gratuite 300/j), valeurs dans SMTP & API → SMTP :
#      MAILER_HOST="smtp-relay.brevo.com"
#      MAILER_PORT="587"
#      MAILER_USER="<email de connexion Brevo, affiché dans le champ 'Login'>"
#      MAILER_PASSWORD="<clé SMTP générée dans Brevo>"
MAILER_HOST=""
MAILER_PORT=""
MAILER_USER=""
MAILER_PASSWORD=""
#
#  • PROD (alternative) : tout dans MAILER_DSN. ⚠️ encoder les caractères spéciaux
#    (le login Brevo est un email : "@" → "%40") :
#      MAILER_DSN="smtp://login%40exemple.fr:CLE_SMTP@smtp-relay.brevo.com:587"

# Adresse expéditrice des emails (champ "From").
# En prod, elle DOIT être un expéditeur vérifié chez Brevo (single sender ou domaine
# avec SPF/DKIM), sinon les mails partent en spam / sont refusés.
ADMIN_MAIL="noreply@ademe.fr"

APP_EMAIL_CONTACT_ADEME="tacct@ademe.fr"
RECEPTION_TEST_EMAIL_ADDRESS="supervision@ademe.fr"

# ── Référentiel territorial ADEME ──
DATA_ADEME_URL="https://data-interne.ademe.fr/data-fair/api/v1/datasets"
REGION_ENDPOINT="/ref-liste-des-regions/lines?format=json&q_mode=simple&qs=DREG_C_ACTIF%3A%22O%22%20AND%20!(DREG_C_CODE%3A%22NR%22)&size=10000&select=DREG_C_CODE%2CDREG_L_LIB_MIN&sampling=max"
DEPARTMENT_ENDPOINT="/ref-liste-des-departements/lines?format=json&q_mode=simple&qs=!(DDEP_C_CODE%3A%22NR%22)%20AND%20DDEP_C_ACTIF%3A%22O%22&size=10000&select=DDEP_C_CODE%2CDREG_C_CODE%2CDDEP_L_LIB_MIN&sampling=max"
COMMUNE_ENDPOINT="/geo-communes/lines?format=json&q_mode=simple&qs=!(DCOE_C_CODE%3A%22NR%22)%20AND%20(DCOE_C_ACTUAL%3A%221%22%20OR%20DCOE_C_ACTUAL%3A%225%22)&sort=DCOE_C_CODE&size=10000&select=DCOE_C_CODE%2CDDEP_C_CODE%2CDCOE_L_LIB_MIN&sampling=max"
REMOVED_COMMUNE_ENDPOINT="/geo-communes/lines?size=9995&sort=DCOE_C_CODE&select=DCOE_C_CODE%2CDCOE_C_ACTUAL%2CDCOE_C_CODE_POLE&sampling=max"
POSTAL_CODE_ENDPOINT="/ref-codes-postaux/lines?format=json&q_mode=simple&sort=CODE_COMMUNE_INSEE%2C-CODE_POSTAL&select=CODE_COMMUNE_INSEE%2CCODE_POSTAL&size=10000&sampling=max"

# ── CRM Connect (ADEME) ──
CRM_CONNECT_URL=""
CRM_CONNECT_CLIENT_ID=""
CRM_CONNECT_CLIENT_SECRET=""
CRM_CONNECT_SOURCE="TACCT"

# ── ReCaptcha (Google) ──
RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET=""

# ── Médias / uploads ──
FILES_DIRECTORY="./var/uploads"
DATA_DIRECTORY="./data"

# ── Supervision ──
APP_SUPERVISION_HOMEPAGE_URL=""
APP_SUPERVISION_CONTACT_PAGE_URL=""
APP_SUPERVISION_VERIFY_SSL="true"
